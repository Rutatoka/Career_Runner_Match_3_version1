    type: 0
    difficulty: 1
    sequenceExample: 2, 4, 6, 8, ?
    correctAnswer: 48
    wrongAnswers: 310039003700
  - name: "\u041E\u0431\u0440\u0430\u0442\u043D\u044B\u0439 \u043F\u043E\u0440\u044F\u0434\u043E\u043A"
    description: "\u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
      \u0438\u0434\u0451\u0442 \u0432 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u043C
      \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438"
    type: 4
    difficulty: 1
    sequenceExample: 5, 4, 3, 2, ?
    correctAnswer: 49
    wrongAnswers: 300036003300
  - name: "\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u0441 \u0431\u0443\u043A\u0432\u0430\u043C\u0438"
    description: "\u0420\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
      \u0431\u0443\u043A\u0432\u0430\u043C\u0438 \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F"
