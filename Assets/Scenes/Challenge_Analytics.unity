    difficulty: 2
    sequenceExample: 1, 2, 4, 8, ?
    correctAnswer: 54
    wrongAnswers: 310033003400
  - name: "\u041F\u0440\u043E\u043F\u0443\u0441\u043A \u0431\u0443\u043A\u0432"
    description: "\u041A\u0430\u0436\u0434\u044B\u0439 \u0440\u0430\u0437 \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0435\u0442\u0441\u044F
