    sequenceExample: "\u0410, \u0411, \u0413, \u0401, ?"
    correctAnswer: 1051
    wrongAnswers: 1a041c041804
  - name: "\u0427\u0435\u0440\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435"
    description: "\u0411\u0443\u043A\u0432\u044B \u0431\u0435\u0440\u0443\u0442\u0441\u044F
      \u0441 \u0440\u0430\u0437\u043D\u044B\u0445 \u043A\u043E\u043D\u0446\u043E\u0432
      \u0430\u043B\u0444\u0430\u0432\u0438\u0442\u0430"
    type: 2
    difficulty: 2
    sequenceExample: "\u0410, \u042F, \u0411, \u042E, \u0412, ?"
    correctAnswer: 1069
    wrongAnswers: 13042c042b04
  - name: "\u0423\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u0435\u043B"
    description: "\u041A\u0430\u0436\u0434\u043E\u0435 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0435
