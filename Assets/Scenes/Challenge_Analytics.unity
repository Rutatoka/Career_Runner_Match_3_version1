    correctAnswer: 1055
    wrongAnswers: 1e0420041b04
  - name: "\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u0447\u0438\u0441\u043B\u0430"
    description: "\u041A\u0430\u0436\u0434\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
