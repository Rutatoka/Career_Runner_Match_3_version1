    type: 0
    difficulty: 1
    sequenceExample: "\u0410, \u0412, \u0414, \u0401, ?"
    correctAnswer: 1047
    wrongAnswers: 160418041504
  - name: "\u0427\u0438\u0441\u043B\u043E\u0432\u0430\u044F \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u044F"
    description: "\u041D\u0430\u0439\u0434\u0438\u0442\u0435 \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
