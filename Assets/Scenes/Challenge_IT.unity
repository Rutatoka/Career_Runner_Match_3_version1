  timerText: {fileID: 1511903568}
  progressText: {fileID: 2081944966}
  feedbackText: {fileID: 1388553528}
  taskText: {fileID: 1349588827}
  taskDatabase:
  - language: Python
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0432\u044B\u0432\u0435\u0441\u0442\u0438
      \u0447\u0438\u0441\u043B\u0430 \u043E\u0442 1 \u0434\u043E 5"
    correctLines:
    - 'for i in range(1, 6):'
    - '    print(i)'
    - "print('\u0413\u043E\u0442\u043E\u0432\u043E')"
    wrongLines:
    - 'for i in range(10, 1):'
    - '    delete(i)'
    - print(undefined)
  - language: Python
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
      \u0447\u0451\u0442\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E"
    correctLines:
    - number = 8
    - 'if number % 2 == 0:'
    - "    print('\u0427\u0451\u0442\u043D\u043E\u0435')"
    wrongLines:
    - number == 8
    - 'if number / 2:'
    - '    print(number - number)'
  - language: JavaScript
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0432\u044B\u0432\u0435\u0441\u0442\u0438
      \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u0432 \u043A\u043E\u043D\u0441\u043E\u043B\u044C"
    correctLines:
    - "let message = '\u041F\u0440\u0438\u0432\u0435\u0442';"
    - console.log(message);
    - alert(message);
    wrongLines:
    - message = console;
    - log.console(message);
    - alert == message;
  - language: JavaScript
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0441\u043B\u043E\u0436\u0438\u0442\u044C
      \u0434\u0432\u0430 \u0447\u0438\u0441\u043B\u0430"
    correctLines:
    - let a = 5;
    - let b = 10;
    - let sum = a + b;
    wrongLines:
    - let a == 5;
    - var b -> 10;
    - sum = a / undefined;
  - language: C#
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0432\u044B\u0432\u0435\u0441\u0442\u0438
      \u043F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435"
    correctLines:
    - "string name = \"\u0418\u0433\u0440\u043E\u043A\";"
    - Debug.Log(name);
    - "Debug.Log(\"\u041F\u0440\u0438\u0432\u0435\u0442!\");"
    wrongLines:
    - "string name == \u0418\u0433\u0440\u043E\u043A;"
    - Log.Debug(name);
    - Debug.Log(name + undefined);
  - language: C#
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0441\u0440\u0430\u0432\u043D\u0438\u0442\u044C
      \u0434\u0432\u0430 \u0447\u0438\u0441\u043B\u0430"
    correctLines:
    - int a = 7;
    - int b = 3;
    - bool result = a > b;
    wrongLines:
    - int a == 7;
    - b = int 3;
    - result == greater(a, b);
  - language: Java
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0432\u044B\u0432\u0435\u0441\u0442\u0438
      \u0447\u0438\u0441\u043B\u043E \u043D\u0430 \u044D\u043A\u0440\u0430\u043D"
    correctLines:
    - int score = 100;
    - System.out.println(score);
    - "System.out.println(\"\u041A\u043E\u043D\u0435\u0446\");"
    wrongLines:
    - int score == 100;
    - println.System(score);
    - System.out(score, end);
  - language: Java
    taskDescription: "\u0421\u043E\u0431\u0435\u0440\u0438 \u043A\u043E\u0434: \u0441\u043E\u0437\u0434\u0430\u0442\u044C
      \u0441\u043F\u0438\u0441\u043E\u043A \u0438\u043C\u0451\u043D"
    correctLines:
    - "String name = \"\u0410\u043D\u044F\";"
    - int age = 15;
    - System.out.println(name);
    wrongLines:
    - "String name == \u0410\u043D\u044F;"
    - age -> 15;
    - println(name, System);
