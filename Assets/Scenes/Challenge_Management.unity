MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 747138132}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9c6eece9d4b936d409ca278b21229b04, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ChallengeManagementController
  requiredCorrect: 4
  resultWindow: {fileID: 1644334898}
  folderButtons:
  - {fileID: 637072410}
  - {fileID: 2095647244}
  - {fileID: 1276360555}
  taskDescriptionText: {fileID: 440487429}
  feedbackText: {fileID: 1041501378}
  taskPanel: {fileID: 645847085}
  progressText: {fileID: 238403174}
  taskDescriptions:
  - "\xAB\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0443\u0442\u0440\u043E\u043C
    \u043A\u043B\u0438\u0435\u043D\u0442 \u043F\u0440\u0438\u0441\u043B\u0430\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E: \u0441\u0435\u0440\u0432\u0435\u0440, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u043D\u0430\u0448 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u043F\u0440\u043E\u0434\u0443\u043A\u0442,
    \u0443\u043F\u0430\u043B. \u041A\u043B\u0438\u0435\u043D\u0442\u044B \u043D\u0435
    \u043C\u043E\u0433\u0443\u0442 \u0432\u043E\u0439\u0442\u0438 \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0443.
    \u0422\u0435\u0445\u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u0443\u0436\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 50 \u0436\u0430\u043B\u043E\u0431.
    \u0415\u0441\u043B\u0438 \u043D\u0435 \u0438\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u0447\u0430\u0441\u0430, \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044F
    \u043F\u043E\u0442\u0435\u0440\u044F\u0435\u0442 1000$ \u0437\u0430 \u043A\u0430\u0436\u0434\u0443\u044E
    \u043C\u0438\u043D\u0443\u0442\u0443 \u043F\u0440\u043E\u0441\u0442\u043E\u044F\xBB."
  - "\xAB\u0417\u0430\u0432\u0442\u0440\u0430 \u0432 10 \u0443\u0442\u0440\u0430
    \u0443 \u0442\u0435\u0431\u044F \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441
    \u0438\u043D\u0432\u0435\u0441\u0442\u043E\u0440\u0430\u043C\u0438. \u0422\u044B
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B \u043F\u0440\u0435\u0437\u0435\u043D\u0442\u0430\u0446\u0438\u044E,
    \u043D\u043E \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439 \u0432\u0435\u0440\u0441\u0438\u0438
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u043E\u0448\u0438\u0431\u043A\u0443
    \u0432 \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u0445. \u0418\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u043C\u043E\u0436\u043D\u043E \u0437\u0430 30 \u043C\u0438\u043D\u0443\u0442,
    \u043D\u043E \u0441\u0435\u0439\u0447\u0430\u0441 \u0442\u044B \u0437\u0430\u043D\u044F\u0442
    \u0441\u0440\u043E\u0447\u043D\u044B\u043C \u0431\u0430\u0433\u043E\u043C \u043D\u0430
    \u0441\u0435\u0440\u0432\u0435\u0440\u0435. \u0412\u0441\u0442\u0440\u0435\u0447\u0430
    \u0432\u0430\u0436\u043D\u0430 \u0434\u043B\u044F \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u0440\u043E\u0435\u043A\u0442\u0430\xBB."
  - "\xAB\u041C\u0435\u043D\u0435\u0434\u0436\u0435\u0440 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B
    \u043E\u0431\u043D\u043E\u0432\u0438\u0442\u044C \u0442\u0430\u0431\u043B\u0438\u0446\u0443
    \u0441 \u043F\u043B\u0430\u043D\u043E\u043C \u043F\u0440\u043E\u0434\u0430\u0436
    \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u043A\u0432\u0430\u0440\u0442\u0430\u043B.
    \u0414\u0430\u043D\u043D\u044B\u0435 \u0435\u0441\u0442\u044C, \u043C\u043E\u0436\u043D\u043E
    \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0437\u0430 \u0447\u0430\u0441. \u041D\u043E
    \u0442\u0435\u043A\u0443\u0449\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F
    \u0443\u0436\u0435 \u0433\u043E\u0442\u043E\u0432\u0430, \u0430 \u043A\u0432\u0430\u0440\u0442\u0430\u043B
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0437 \u043C\u0435\u0441\u044F\u0446.
    \u0415\u0441\u043B\u0438 \u043D\u0435 \u043E\u0431\u043D\u043E\u0432\u0438\u0442\u044C
    \u0441\u0435\u0439\u0447\u0430\u0441, \u043D\u0438\u0447\u0435\u0433\u043E \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043D\u0435 \u0441\u043B\u0443\u0447\u0438\u0442\u0441\u044F\xBB."
  - "\xAB\u041A\u043E\u043B\u043B\u0435\u0433\u0430 \u0438\u0437 \u043E\u0442\u0434\u0435\u043B\u0430
    \u043C\u0430\u0440\u043A\u0435\u0442\u0438\u043D\u0433\u0430 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B
    \u0441\u0440\u043E\u0447\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0442\u0435\u043A\u0441\u0442 \u0434\u043B\u044F \u0440\u0435\u043A\u043B\u0430\u043C\u043D\u043E\u0433\u043E
    \u0431\u0430\u043D\u043D\u0435\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0435\u0442\u0441\u044F \u0447\u0435\u0440\u0435\u0437
    2 \u0447\u0430\u0441\u0430. \u0412 \u0442\u0435\u043A\u0441\u0442\u0435 \u0435\u0441\u0442\u044C
    \u043E\u0440\u0444\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u0448\u0438\u0431\u043A\u0430. \u0415\u0441\u043B\u0438 \u0435\u0451 \u043D\u0435
    \u0438\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C, \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044F
    \u0431\u0443\u0434\u0435\u0442 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u0442\u044C
    \u043D\u0435\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E.
    \u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0437\u0430 5 \u043C\u0438\u043D\u0443\u0442\xBB."
  - "\xAB\u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C
    \u043E\u0442\u0447\u0435\u0442 \u043F\u043E \u0438\u0442\u043E\u0433\u0430\u043C
    \u043A\u0432\u0430\u0440\u0442\u0430\u043B\u0430 \u0434\u043B\u044F \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0433\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F.
    \u041E\u0442\u0447\u0435\u0442 \u043D\u0443\u0436\u0435\u043D \u0447\u0435\u0440\u0435\u0437
    \u0434\u0432\u0435 \u043D\u0435\u0434\u0435\u043B\u0438. \u0414\u0430\u043D\u043D\u044B\u0435
    \u0435\u0441\u0442\u044C, \u043D\u043E \u0438\u0445 \u043D\u0443\u0436\u043D\u043E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C.
    \u041D\u0430 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0443 \u0443\u0439\u0434\u0435\u0442
    2 \u0434\u043D\u044F. \u0415\u0441\u043B\u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0441\u0435\u0439\u0447\u0430\u0441, \u0431\u0443\u0434\u0435\u0442 \u043C\u0435\u043D\u044C\u0448\u0435
    \u0441\u0442\u0440\u0435\u0441\u0441\u0430 \u043F\u0435\u0440\u0435\u0434 \u0434\u0435\u0434\u043B\u0430\u0439\u043D\u043E\u043C,
    \u043D\u043E \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0441\u043B\u0443\u0447\u0438\u0442\u0441\u044F,
    \u0435\u0441\u043B\u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043F\u043E\u0437\u0436\u0435\xBB."
